Cell[BoxData[{
 RowBox[{"Clear", "[", 
  RowBox[{"RunOnce2", ",", "\[Omega]", ",", "q"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"mu", "=", 
  RowBox[{
   RowBox[{"Interpreter", "[", "\"\<Number\>\"", "]"}], "[", "mutrate", 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"RunOnce2", "[", 
   RowBox[{
    RowBox[{"\[Omega]_", "?", "NumericQ"}], ",", 
    RowBox[{"q_", "?", "NumericQ"}]}], "]"}], ":=", 
  RowBox[{
   RowBox[{"RunOnce2", "[", 
    RowBox[{"\[Omega]", ",", "q"}], "]"}], "=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "pval1", ",", "pval2", ",", "pval3", ",", "simcfus", ",", "simdist", ",",
        "tmp", ",", "psurv", ",", "psurvexp", ",", "ret", ",", "processes", ",",
        "fractions"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{"Return", "[", 
       RowBox[{
        RowBox[{"\[Omega]", "^", "2"}], "+", 
        RowBox[{"q", "^", "2"}]}], "]"}], "*)"}], "\[IndentingNewLine]", 
     RowBox[{
