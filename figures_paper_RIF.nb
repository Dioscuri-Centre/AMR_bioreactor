             "&"}]}], "]"}]}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", 
           RowBox[{"Length", "[", "simdist", "]"}]}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"pval3", "=", 
       RowBox[{"KolmogorovSmirnovTest", "[", 
        RowBox[{
         RowBox[{"Round", "[", 
          RowBox[{
           RowBox[{"Flatten", "[", "fractions", "]"}], ",", "ksround"}], 
          "]"}], ",", 
         RowBox[{"Round", "[", 
          RowBox[{"experfractions", ",", "ksround"}], "]"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"ret", "=", 
       RowBox[{"-", 
        RowBox[{"FittingFunction", "[", 
         RowBox[{"pval1", ",", "pval2", ",", "pval3"}], "]"}]}]}], ";", 
