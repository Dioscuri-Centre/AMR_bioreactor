            RowBox[{
             RowBox[{"NumberQ", "[", 
              RowBox[{
              "#1", "\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}], 
              "]"}], "&"}]}], "]"}], "]"}], ",", 
         RowBox[{"Length", "[", "tmp", "]"}], ",", 
         RowBox[{"Length", "[", 
          RowBox[{"Select", "[", 
           RowBox[{"tregrowths", ",", 
            RowBox[{
             RowBox[{"NumberQ", "[", "#1", "]"}], "&"}]}], "]"}], "]"}], ",", 
         RowBox[{"Length", "[", "tregrowths", "]"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"fractions", "=", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"Min", "[", 
            RowBox[{
             RowBox[{"1.", 
              RowBox[{
               RowBox[{"#", "[", 
                RowBox[{"[", "7", "]"}], "]"}], "/", 
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"#", "[", 
                  RowBox[{"[", "10", "]"}], "]"}], "+", 
                 RowBox[{"#", "[", 
                  RowBox[{"[", "7", "]"}], "]"}]}], ")"}]}]}], ",", 
             RowBox[{"1.", 
              RowBox[{
               RowBox[{"#", "[", 
                RowBox[{"[", "10", "]"}], "]"}], "/", 
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"#", "[", 
                  RowBox[{"[", "10", "]"}], "]"}], "+", 
                 RowBox[{"#", "[", 
                  RowBox[{"[", "7", "]"}], "]"}]}], ")"}]}]}]}], "]"}], "&"}],
           "/@", 
          RowBox[{"Select", "[", 
           RowBox[{
            RowBox[{"simdist", "[", 
             RowBox[{"[", "i", "]"}], "]"}], ",", 
            RowBox[{
             RowBox[{"(", 
