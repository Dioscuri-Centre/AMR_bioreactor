             "&"}]}], "]"}]}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", 
           RowBox[{"Length", "[", "simdist", "]"}]}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"pval3", "=", 
       RowBox[{"KolmogorovSmirnovTest", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Flatten", "[", "fractions", "]"}], "[", 
          RowBox[{"[", 
           RowBox[{";;", ";;", "2"}], "]"}], "]"}], ",", "experfractions"}], 
        "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"ret", "=", 
       RowBox[{"-", 
        RowBox[{"FittingFunction", "[", 
         RowBox[{"pval1", ",", "pval2", ",", "pval3"}], "]"}]}]}], ";", 
      "\[IndentingNewLine]", 
