Cell[CellGroupData[{

Cell["\<\
Find the optimal \[Mu] that maximizes the p - value of the probability of \
regrowth\
\>", "Subsection",
 CellChangeTimes->{{3.926674713045538*^9, 3.9266747300869446`*^9}, {
  3.93185855814876*^9, 3.931858563042343*^9}, {3.9610337627652416`*^9, 
  3.9610337790970306`*^9}},ExpressionUUID->"6b78ad74-a3e7-4b13-b450-\
5b20b6b04184"],

Cell[BoxData[{
 RowBox[{"Clear", "[", 
  RowBox[{"RunOnce0", ",", "mu"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"RunOnce0", "[", "mu_", "]"}], ":=", 
  RowBox[{
   RowBox[{"RunOnce", "[", "mu", "]"}], "=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "pval", ",", "simcfus", ",", "processes", ",", "tmp", ",", "simdist"}], 
      "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"SetDirectory", "[", 
       RowBox[{
        RowBox[{"NotebookDirectory", "[", "]"}], 
        "<>", "\"\<\\\\models\\\\STR\>\""}], "]"}], ";", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"args", "=", 
       RowBox[{"Table", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"\"\<optimization\>\"", "<>", 
            RowBox[{"ToString", "[", "nn", "]"}]}], ",", 
           RowBox[{"ToString", "[", 
            RowBox[{"vols", "[", 
             RowBox[{"[", "nn", "]"}], "]"}], "]"}], ",", 
           RowBox[{"ToString", "[", 
            RowBox[{"odinis", "[", 
             RowBox[{"[", "nn", "]"}], "]"}], "]"}], ",", 
           RowBox[{"ToString", "[", 
            RowBox[{"ainjs", "[", 
             RowBox[{"[", "nn", "]"}], "]"}], "]"}], ",", 
           RowBox[{"ToString", "[", 
            RowBox[{"tends", "[", 
             RowBox[{"[", "nn", "]"}], "]"}], "]"}], ",", 
           RowBox[{"ToString", "[", 
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"tregrowths", "[", 
                RowBox[{"[", "nn", "]"}], "]"}], "\[NotEqual]", 
               "\[Infinity]"}], ",", 
              RowBox[{"tregrowths", "[", 
               RowBox[{"[", "nn", "]"}], "]"}], ",", "tmax"}], "]"}], "]"}], ",", 
           RowBox[{"ToString", "[", "odregrowth", "]"}], ",", "\"\<300\>\"", ",", 
           RowBox[{"ToString", "[", 
            RowBox[{"mu", ",", "CForm"}], "]"}], ",", 
           RowBox[{"ToString", "[", 
            RowBox[{"mu", ",", "CForm"}], "]"}], ",", 
           RowBox[{"ToString", "[", "dilf", "]"}], ",", 
           RowBox[{"(", 
            RowBox[{"\"\<input_params_\>\"", "<>", 
             RowBox[{"ToString", "[", "nn", "]"}], "<>", "\"\<.dat\>\""}], 
            ")"}], ",", "\"\<0.1\>\""}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"nn", ",", 
           RowBox[{"Length", "[", "vols", "]"}]}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"name", "=", 
       RowBox[{"\"\<..\\\\create_processes.exe \
..\\\\turbidostat_evolution_for_Bayesian_many_strains_many_muts_ind_params.\
exe \>\"", "<>", 
        RowBox[{"ToString", "[", 
         RowBox[{"Length", "[", "args", "]"}], "]"}], "<>", "\"\< \>\"", "<>", 
        RowBox[{"ToString", "[", 
         RowBox[{"Length", "[", 
          RowBox[{"args", "[", 
           RowBox[{"[", "1", "]"}], "]"}], "]"}], "]"}], "<>", "\"\< \>\"", "<>", 
        RowBox[{"StringJoin", "[", 
         RowBox[{"Riffle", "[", 
          RowBox[{
           RowBox[{"Flatten", "[", "args", "]"}], ",", "\"\< \>\""}], "]"}], 
         "]"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{"Run", "[", 
        RowBox[{"\"\<powershell -NoExit \>\"", "<>", "name"}], "]"}], "*)"}], 
      "\[IndentingNewLine]", 
      RowBox[{"ret", "=", 
       RowBox[{"RunProcess", "[", 
        RowBox[{"{", 
         RowBox[{"\"\<powershell\>\"", ",", "name"}], "}"}], "]"}]}], ";", 
      " ", 
      RowBox[{"(*", " ", 
       RowBox[{
       "waits", " ", "until", " ", "the", " ", "process", " ", "exits"}], " ",
        "*)"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"simdist", "=", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"Import", "[", 
          RowBox[{
           RowBox[{"\"\<distribution_optimization\>\"", "<>", 
            RowBox[{"ToString", "[", "nn", "]"}], "<>", "\"\<.dat\>\""}], 
           ",", "\"\<Table\>\""}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"nn", ",", 
           RowBox[{"Length", "[", "births", "]"}]}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"tmp", "=", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"NumberQ", "[", 
              RowBox[{"#", "[", 
               RowBox[{"[", "2", "]"}], "]"}], "]"}], ",", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"#", "[", 
                RowBox[{"[", "1", "]"}], "]"}], ",", 
               RowBox[{
                RowBox[{"#", "[", 
                 RowBox[{"[", "2", "]"}], "]"}], "-", 
                RowBox[{"ainjs", "[", 
                 RowBox[{"[", "i", "]"}], "]"}]}], ",", 
               RowBox[{"#", "[", 
                RowBox[{"[", "3", "]"}], "]"}], ",", 
               RowBox[{
                RowBox[{"#", "[", 
                 RowBox[{"[", "4", "]"}], "]"}], "-", 
                RowBox[{"ainjs", "[", 
                 RowBox[{"[", "i", "]"}], "]"}]}]}], "}"}], ",", "#"}], "]"}],
            "&"}], "/@", 
          RowBox[{"Select", "[", 
           RowBox[{
            RowBox[{"simdist", "[", 
             RowBox[{"[", "i", "]"}], "]"}], ",", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{
               RowBox[{"Abs", "[", 
                RowBox[{
                 RowBox[{"#", "[", 
                  RowBox[{"[", "3", "]"}], "]"}], "-", 
                 RowBox[{"tfirstthr", "[", 
                  RowBox[{"[", "i", "]"}], "]"}]}], "]"}], "<", "0.2"}], 
              ")"}], "&"}]}], "]"}]}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", 
           RowBox[{"Length", "[", "simdist", "]"}]}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"tmp", "=", 
       RowBox[{"Flatten", "[", 
        RowBox[{"tmp", ",", "1"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"SetDirectory", "[", 
       RowBox[{"NotebookDirectory", "[", "]"}], "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"pval", "=", 
       RowBox[{"FisherExactTest", "[", 
        RowBox[{
         RowBox[{"Length", "[", 
          RowBox[{"Select", "[", 
           RowBox[{"tmp", ",", 
            RowBox[{
             RowBox[{"NumberQ", "[", 
              RowBox[{
              "#1", "\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}], 
              "]"}], "&"}]}], "]"}], "]"}], ",", 
         RowBox[{"Length", "[", "tmp", "]"}], ",", 
         RowBox[{"Length", "[", 
          RowBox[{"Select", "[", 
           RowBox[{"tregrowths", ",", 
            RowBox[{
             RowBox[{"NumberQ", "[", "#1", "]"}], "&"}]}], "]"}], "]"}], ",", 
         RowBox[{"Length", "[", "tregrowths", "]"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Return", "[", 
       RowBox[{"-", "pval"}], "]"}]}]}], "]"}]}]}]}], "Input",
 CellChangeTimes->{{3.931856547758862*^9, 3.931856548714163*^9}, {
   3.931858594612459*^9, 3.9318586541103573`*^9}, {3.9318587221503983`*^9, 
   3.931858744487958*^9}, 3.9318588438375793`*^9, {3.931859121863073*^9, 
   3.93185914494099*^9}, {3.9318591893425407`*^9, 3.931859201419779*^9}, 
