Cell[CellGroupData[{

Cell["\<\
Find the optimal \[Mu] that maximizes the p - value when fitted to the mutant \
number distribution (only large colonies):\
\>", "Subsection",
 CellChangeTimes->{{3.926674713045538*^9, 3.9266747300869446`*^9}, {
  3.9325609384764833`*^9, 3.932560943055244*^9}, {3.9610339296035213`*^9, 
  3.961033946158947*^9}},ExpressionUUID->"e450d41c-fda4-4da0-a6aa-\
a12173b4ed2a"],

Cell[BoxData[{
 RowBox[{"Clear", "[", 
  RowBox[{"RunOnce", ",", "mu"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"RunOnce", "[", "mu_", "]"}], ":=", 
  RowBox[{
   RowBox[{"RunOnce", "[", "mu", "]"}], "=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"pval", ",", "simcfus", ",", "processes"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"SetDirectory", "[", 
       RowBox[{
        RowBox[{"NotebookDirectory", "[", "]"}], 
        "<>", "\"\<\\\\models\\\\STR\>\""}], "]"}], ";", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"args", "=", 
       RowBox[{"Table", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"\"\<optimization\>\"", "<>", 
            RowBox[{"ToString", "[", "nn", "]"}]}], ",", 
           RowBox[{"ToString", "[", 
            RowBox[{"vols2", "[", 
             RowBox[{"[", "nn", "]"}], "]"}], "]"}], ",", 
           RowBox[{"ToString", "[", 
            RowBox[{"odinis2", "[", 
             RowBox[{"[", "nn", "]"}], "]"}], "]"}], ",", 
           RowBox[{"ToString", "[", "100", "]"}], ",", 
           RowBox[{"ToString", "[", 
            RowBox[{"tends2", "[", 
             RowBox[{"[", "nn", "]"}], "]"}], "]"}], ",", 
           RowBox[{"ToString", "[", "100", "]"}], ",", 
           RowBox[{"ToString", "[", "odregrowth", "]"}], ",", "\"\<100\>\"", ",", 
           RowBox[{"ToString", "[", 
            RowBox[{"mu", ",", "CForm"}], "]"}], ",", 
           RowBox[{"ToString", "[", 
            RowBox[{"mu", ",", "CForm"}], "]"}], ",", 
           RowBox[{"ToString", "[", "dilf2", "]"}], ",", 
           RowBox[{"(", 
            RowBox[{"\"\<input_params_\>\"", "<>", 
             RowBox[{"ToString", "[", "nn", "]"}], "<>", "\"\<.dat\>\""}], 
            ")"}], ",", "\"\<0.1\>\""}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"nn", ",", 
           RowBox[{"Length", "[", "births2", "]"}]}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"name", "=", 
       RowBox[{"\"\<..\\\\create_processes.exe \
..\\\\turbidostat_evolution_for_Bayesian_many_strains_many_muts_ind_params.\
exe \>\"", "<>", 
        RowBox[{"ToString", "[", 
         RowBox[{"Length", "[", "args", "]"}], "]"}], "<>", "\"\< \>\"", "<>", 
        RowBox[{"ToString", "[", 
         RowBox[{"Length", "[", 
          RowBox[{"args", "[", 
           RowBox[{"[", "1", "]"}], "]"}], "]"}], "]"}], "<>", "\"\< \>\"", "<>", 
        RowBox[{"StringJoin", "[", 
         RowBox[{"Riffle", "[", 
          RowBox[{
           RowBox[{"Flatten", "[", "args", "]"}], ",", "\"\< \>\""}], "]"}], 
