                RowBox[{
                 RowBox[{"#", "[", 
                  RowBox[{"[", "10", "]"}], "]"}], "+", 
                 RowBox[{"#", "[", 
                  RowBox[{"[", "7", "]"}], "]"}]}], ")"}]}]}]}], "]"}], "&"}],
           "/@", 
          RowBox[{"Select", "[", 
           RowBox[{
            RowBox[{"simdist", "[", 
             RowBox[{"[", "i", "]"}], "]"}], ",", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{
               RowBox[{
                RowBox[{"#", "[", 
                 RowBox[{"[", "7", "]"}], "]"}], "+", 
