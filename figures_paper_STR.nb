            RowBox[{"Frame", "\[Rule]", "True"}], ",", 
            RowBox[{"FrameLabel", "\[Rule]", 
             RowBox[{"{", 
              
              RowBox[{"\"\<\!\(\*SubscriptBox[\(n\), \(r\)]\)\>\"", ",", 
               "None"}], 
              RowBox[{"(*", "\"\<PDF\>\"", "*)"}], "}"}]}], ",", 
            RowBox[{"PlotRange", "->", 
             RowBox[{"{", 
