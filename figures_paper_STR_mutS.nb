            RowBox[{"NumberQ", "[", "#1", "]"}], "&"}]}], "]"}], ",", 
         RowBox[{"Select", "[", 
          RowBox[{
           RowBox[{"tregrowths", "-", "ainjs"}], ",", 
           RowBox[{
            RowBox[{"NumberQ", "[", "#1", "]"}], "&"}]}], "]"}]}], "]"}]}], ";",
       "\[IndentingNewLine]", 
      RowBox[{"pval1", "=", 
       RowBox[{"FisherExactTest", "[", 
