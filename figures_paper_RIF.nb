           ",", "\"\<Table\>\""}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"nn", ",", 
           RowBox[{"Length", "[", "births", "]"}]}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"tmp", "=", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"NumberQ", "[", 
              RowBox[{"#", "[", 
               RowBox[{"[", "2", "]"}], "]"}], "]"}], ",", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"#", "[", 
                RowBox[{"[", "1", "]"}], "]"}], ",", 
               RowBox[{
                RowBox[{"#", "[", 
                 RowBox[{"[", "2", "]"}], "]"}], "-", 
                RowBox[{"ainjs", "[", 
                 RowBox[{"[", "i", "]"}], "]"}]}], ",", 
               RowBox[{"#", "[", 
                RowBox[{"[", "3", "]"}], "]"}], ",", 
               RowBox[{
                RowBox[{"#", "[", 
                 RowBox[{"[", "4", "]"}], "]"}], "-", 
                RowBox[{"ainjs", "[", 
                 RowBox[{"[", "i", "]"}], "]"}]}]}], "}"}], ",", "#"}], "]"}],
            "&"}], "/@", 
          RowBox[{"Select", "[", 
           RowBox[{
            RowBox[{"simdist", "[", 
             RowBox[{"[", "i", "]"}], "]"}], ",", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{
               RowBox[{"Abs", "[", 
                RowBox[{
                 RowBox[{"#", "[", 
                  RowBox[{"[", "3", "]"}], "]"}], "-", 
                 RowBox[{"tfirstthr", "[", 
                  RowBox[{"[", "i", "]"}], "]"}]}], "]"}], "<", "0.2"}], 
              ")"}], "&"}]}], "]"}]}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", 
           RowBox[{"Length", "[", "simdist", "]"}]}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"tmp", "=", 
       RowBox[{"Flatten", "[", 
        RowBox[{"tmp", ",", "1"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"pval2", "=", 
       RowBox[{"KolmogorovSmirnovTest", "[", 
        RowBox[{
         RowBox[{"Select", "[", 
          RowBox[{
           RowBox[{"tmp", "\[LeftDoubleBracket]", 
            RowBox[{"All", ",", "2"}], "\[RightDoubleBracket]"}], ",", 
