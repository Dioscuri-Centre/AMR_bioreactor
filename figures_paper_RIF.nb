             RowBox[{"wt", "[", 
              RowBox[{"[", "1", "]"}], "]"}], ",", 
             RowBox[{"it", "[", 
              RowBox[{"[", "1", "]"}], "]"}], ",", 
             RowBox[{"mt", "[", 
              RowBox[{"[", "1", "]"}], "]"}], ",", 
             RowBox[{"wt", "[", 
              RowBox[{"[", "2", "]"}], "]"}], ",", 
             RowBox[{"it", "[", 
              RowBox[{"[", "2", "]"}], "]"}], ",", 
             RowBox[{"mt", "[", 
