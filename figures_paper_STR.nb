             RowBox[{
              RowBox[{"(", 
               RowBox[{"#", "<", "0.1"}], ")"}], "&"}]}], "]"}], "]"}], "/", 
          RowBox[{"Length", "[", 
           RowBox[{"Flatten", "[", "fractions", "]"}], "]"}]}]}]}], "]"}], 
      ";"}]}], "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"Clear", "[", "HistogramMutants", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"HistogramMutants", "[", 
   RowBox[{
   "cfus_", ",", "namepart_", ",", "strains_", ",", "alleles_", ",", 
    "output_", ",", "cfubindata_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"types", "=", 
       RowBox[{"Table", "[", 
        RowBox[{"Number", ",", 
         RowBox[{"{", 
          RowBox[{"strains", "*", 
           RowBox[{"(", 
            RowBox[{"alleles", "+", "1"}], ")"}]}], "}"}]}], "]"}]}], ",", 
      "simcfus", ",", "thcfus"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{"(*", " ", 
     RowBox[{
      RowBox[{
      "this", " ", "simpler", " ", "method", " ", "ignores", " ", "fitting", " ",
        "the", " ", "tfirstthr", " ", "times"}], ",", " ", 
      RowBox[{
      "but", " ", "works", " ", "nevertheless", " ", "and", " ", "is", " ", 
       "much", " ", "faster"}]}], " ", "*)"}], "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"simcfus", "=", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"ReadList", "[", 
         RowBox[{
          RowBox[{"namepart", "<>", 
           RowBox[{"ToString", "[", "n", "]"}], "<>", "\"\<.dat\>\""}], ",", 
          "types"}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"n", ",", 
          RowBox[{"Length", "[", "births2", "]"}]}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"thcfus", "=", 
      RowBox[{"Select", "[", 
       RowBox[{
        RowBox[{"Flatten", "[", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"Table", "[", 
            RowBox[{
             RowBox[{"Total", "[", 
              RowBox[{"simcfus", "[", 
               RowBox[{"[", 
                RowBox[{"k", ",", "i", ",", 
                 RowBox[{"3", ";;"}]}], "]"}], "]"}], "]"}], ",", 
             RowBox[{"{", 
              RowBox[{"i", ",", 
               RowBox[{"Length", "[", 
                RowBox[{"simcfus", "[", 
                 RowBox[{"[", "k", "]"}], "]"}], "]"}]}], "}"}]}], "]"}], ",", 
           RowBox[{"{", 
            RowBox[{"k", ",", 
             RowBox[{"Length", "[", "simcfus", "]"}]}], "}"}]}], "]"}], "]"}],
         ",", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"#", "<=", 
           RowBox[{"Max", "[", "cfus", "]"}]}], ")"}], "&"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"Length", "[", "simcfus", "]"}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"pl", "=", 
      RowBox[{"Show", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"Histogram", "[", 
           RowBox[{"cfus", ",", 
            RowBox[{"{", 
             RowBox[{"0", ",", 
