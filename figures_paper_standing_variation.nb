Cell[CellGroupData[{

Cell["Distribution of regrowth times (CIP)", "Subsubsection",
 CellChangeTimes->{{3.940391358430185*^9, 3.940391366679672*^9}, 
   3.951746286884681*^9, {3.9609101110579967`*^9, 
   3.9609101169893627`*^9}},ExpressionUUID->"ce9b2f39-e940-0c4c-b589-\
6fd2ea03781d"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"Clear", "[", "RegrowtTimeDistribution", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"RegrowtTimeDistribution", "[", "name_", "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"gr", ",", "pval", ",", "tmp", ",", "grth", ",", "grexp"}], 
      "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"tmp", "=", 
       RowBox[{"Flatten", "[", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{"NumberQ", "[", 
               RowBox[{"#", "[", 
                RowBox[{"[", "1", "]"}], "]"}], "]"}], ",", 
              RowBox[{
               RowBox[{"#", "[", 
                RowBox[{"[", "1", "]"}], "]"}], "-", 
               RowBox[{"ainjs", "[", 
                RowBox[{"[", "i", "]"}], "]"}]}], ",", "#"}], "]"}], "&"}], "/@", 
           RowBox[{"Select", "[", 
            RowBox[{
             RowBox[{"simdist", "[", 
              RowBox[{"[", "i", "]"}], "]"}], ",", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{
                RowBox[{"Abs", "[", 
                 RowBox[{
                  RowBox[{"#", "[", 
                   RowBox[{"[", "2", "]"}], "]"}], "-", 
                  RowBox[{"tfirstthr", "[", 
                   RowBox[{"[", "i", "]"}], "]"}]}], "]"}], "<", "0.1"}], 
               ")"}], "&"}]}], "]"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", 
            RowBox[{"Length", "[", "simdist", "]"}]}], "}"}]}], "]"}], 
        "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"grth", "=", 
       RowBox[{"SmoothHistogram", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Select", "[", 
           RowBox[{"tmp", ",", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"NumberQ", "[", "#", "]"}], ")"}], "&"}], ")"}]}], 
           "]"}], "[", 
          RowBox[{"[", "All", "]"}], "]"}], ",", "Automatic", 
         ",", "\"\<PDF\>\"", ",", 
         RowBox[{"PlotStyle", "\[Rule]", 
          RowBox[{"Darker", "[", "Green", "]"}]}], ",", 
         RowBox[{"Filling", "->", "Bottom"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"grexp", "=", 
       RowBox[{"Histogram", "[", 
        RowBox[{
         RowBox[{"Select", "[", 
          RowBox[{
           RowBox[{"tregrowths", "-", "ainjs"}], ",", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"#", "\[NotEqual]", "\[Infinity]"}], ")"}], "&"}]}], 
          "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"8", ",", "14", ",", 
           RowBox[{"1", "/", "2"}]}], "}"}], ",", "\"\<PDF\>\"", ",", 
         RowBox[{"ChartStyle", "\[Rule]", 
          RowBox[{"Opacity", "[", 
           RowBox[{"0.5", ",", "Black"}], "]"}]}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"gr", "=", 
       RowBox[{"Show", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"grexp", ",", "grth"}], "}"}], 
         RowBox[{"(*", 
          RowBox[{"Epilog", "\[Rule]", 
           RowBox[{"{", 
            RowBox[{"Red", ",", 
             RowBox[{"PointSize", "[", "0.02", "]"}], ",", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{
                RowBox[{"Point", "[", 
                 RowBox[{"{", 
                  RowBox[{"#", ",", "0.02"}], "}"}], "]"}], "&"}], "/@", 
               RowBox[{"Select", "[", 
                RowBox[{
                 RowBox[{"tregrowths", "-", 
                  RowBox[{"Ainjs", "[", 
                   RowBox[{"[", 
                    RowBox[{"All", ",", "1", ",", "1"}], "]"}], "]"}]}], ",", 
                 RowBox[{
                  RowBox[{"(", 
                   RowBox[{"#", "\[NotEqual]", "\[Infinity]"}], ")"}], 
                  "&"}]}], "]"}]}], ")"}]}], "}"}]}], "*)"}], ",", 
         RowBox[{"Frame", "\[Rule]", "True"}], ",", 
         RowBox[{"FrameLabel", "\[Rule]", 
          RowBox[{"{", 
           
           RowBox[{"\"\<\!\(\*SubscriptBox[\(t\), \(regrowth\)]\) - \
\!\(\*SubscriptBox[\(t\), \(0\)]\) [h]\>\"", ",", "None"}], "}"}]}], ",", 
         RowBox[{"AspectRatio", "\[Rule]", "1"}], ",", 
         RowBox[{"ImageSize", "\[Rule]", "250"}], 
         RowBox[{"(*", 
          RowBox[{",", 
           RowBox[{"ChartLegends", "\[Rule]", 
            RowBox[{"{", 
             RowBox[{"\"\<sim\>\"", ",", "\"\<exp\>\""}], "}"}]}]}], "*)"}], ",", 
         RowBox[{"PlotRange", "->", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"8", ",", "14"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"0", ",", "All"}], "}"}]}], "}"}]}], ",", 
         RowBox[{"PlotLabel", "->", 
          RowBox[{"Style", "[", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"\"\<\!\(\*SubscriptBox[\(p\), \(value\)]\)= \>\"", "<>", 
              RowBox[{"DispPval", "[", 
               RowBox[{"KolmogorovSmirnovTest", "[", 
                RowBox[{
                 RowBox[{"Select", "[", 
                  RowBox[{
                   RowBox[{"tmp", "[", 
                    RowBox[{"[", "All", "]"}], "]"}], ",", 
                   RowBox[{
                    RowBox[{"NumberQ", "[", "#", "]"}], "&"}]}], "]"}], ",", 
                 RowBox[{"Select", "[", 
                  RowBox[{
                   RowBox[{"(", 
                    RowBox[{"tregrowths", "-", "ainjs"}], ")"}], ",", 
                   RowBox[{
                    RowBox[{"NumberQ", "[", "#", "]"}], "&"}]}], "]"}]}], 
                "]"}], "]"}]}], ")"}], ",", "24"}], "]"}]}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Print", "[", "gr", "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"Export", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"NotebookDirectory", "[", "]"}], 
         "<>", "\"\<\\\\figures\\\\\>\"", "<>", "name"}], ",", "gr", 
        ",", "\"\<PNG\>\""}], "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"pval", "=", 
       RowBox[{"KolmogorovSmirnovTest", "[", 
        RowBox[{
         RowBox[{"Select", "[", 
          RowBox[{
           RowBox[{"tmp", "[", 
            RowBox[{"[", "All", "]"}], "]"}], ",", 
           RowBox[{
            RowBox[{"NumberQ", "[", "#", "]"}], "&"}]}], "]"}], ",", 
         RowBox[{"Select", "[", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"tregrowths", "-", "ainjs"}], ")"}], ",", 
           RowBox[{
            RowBox[{"NumberQ", "[", "#", "]"}], "&"}]}], "]"}]}], "]"}]}], ";",
       "\[IndentingNewLine]", 
      RowBox[{"Print", "[", 
       RowBox[{"\"\<KS-test p-value: \>\"", ",", "pval"}], "]"}]}]}], "]"}]}],
   "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"RegrowtTimeDistribution", "[", "\"\<CIP_spike_in_Pregrowth.png\>\"",
   "]"}]}], "Input",
 CellChangeTimes->{{3.940390999678296*^9, 3.940390999895671*^9}, {
  3.940391494353325*^9, 3.940391494920943*^9}, {3.940697190298337*^9, 
