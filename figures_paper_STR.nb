     RowBox[{
      RowBox[{"a", "=", 
       RowBox[{"1.", "a0"}]}], ";", 
      RowBox[{"b", "=", 
       RowBox[{"1.", "b0"}]}], ";", 
      RowBox[{"Do", "[", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{"c", "=", 
          RowBox[{"b", "-", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"b", "-", "a"}], ")"}], "/", "gr"}]}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"d", "=", 
          RowBox[{"a", "+", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"b", "-", "a"}], ")"}], "/", "gr"}]}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"fa", "=", 
          RowBox[{"fun", "[", "a", "]"}]}], ";", 
         RowBox[{"fb", "=", 
          RowBox[{"fun", "[", "b", "]"}]}], ";", 
