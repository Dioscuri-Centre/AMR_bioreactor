Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"Clear", "[", 
  RowBox[{"RunOnce1", ",", "\[Omega]", ",", "q"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"mu", "=", 
  RowBox[{
   RowBox[{"Interpreter", "[", "\"\<Number\>\"", "]"}], "[", "mutrate", 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"SeedRandom", "[", "1234", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"RunOnce1", "[", 
   RowBox[{
    RowBox[{"\[Omega]_", "?", "NumericQ"}], ",", 
    RowBox[{"q_", "?", "NumericQ"}]}], "]"}], ":=", 
  RowBox[{
   RowBox[{"RunOnce1", "[", 
    RowBox[{"\[Omega]", ",", "q"}], "]"}], "=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "pval1", ",", "pval2", ",", "pval3", ",", "simcfus", ",", "simdist", ",",
        "tmp", ",", "psurv", ",", "psurvexp", ",", "ret", ",", "processes", ",",
        "fractions"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{"Return", "[", 
       RowBox[{
        RowBox[{"\[Omega]", "^", "2"}], "+", 
        RowBox[{"q", "^", "2"}]}], "]"}], "*)"}], "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"strains", "=", "2"}], ";", 
      RowBox[{"alleles", "=", "1"}], ";", "\[IndentingNewLine]", 
      RowBox[{"mutprobs", "=", 
       RowBox[{"{", 
        RowBox[{"1", ",", "1"}], "}"}]}], "  ", ";", 
      RowBox[{"(*", " ", 
       RowBox[{
       "same", " ", "mutation", " ", "probs", " ", "for", " ", "all", " ", 
        "alleles"}], " ", "*)"}], "\[IndentingNewLine]", 
      RowBox[{"Do", "[", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{"wt", "=", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"Table", "[", 
             RowBox[{
              RowBox[{"births", "[", 
               RowBox[{"[", 
                RowBox[{"nn", ",", "1"}], "]"}], "]"}], ",", 
              RowBox[{"{", 
               RowBox[{"i", ",", "strains"}], "}"}]}], "]"}], ",", 
            RowBox[{"Table", "[", 
             RowBox[{"0", ",", 
              RowBox[{"{", 
               RowBox[{"i", ",", "strains"}], "}"}]}], "]"}]}], "}"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"it", "=", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{
             RowBox[{"births", "[", 
              RowBox[{"[", 
               RowBox[{"nn", ",", "1"}], "]"}], "]"}], 
             RowBox[{"{", 
              RowBox[{"1", ",", "1"}], "}"}]}], ",", 
            RowBox[{
             RowBox[{"Abs", "[", "q", "]"}], " ", 
             RowBox[{"If", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"birthsres", "[", 
                 RowBox[{"[", 
                  RowBox[{"nn", ",", "1"}], "]"}], "]"}], ">", "0"}], ",", 
               RowBox[{"birthsres", "[", 
                RowBox[{"[", 
                 RowBox[{"nn", ",", "1"}], "]"}], "]"}], ",", 
               RowBox[{"RandomChoice", "[", 
                RowBox[{"Select", "[", 
                 RowBox[{
                  RowBox[{"birthsres", "[", 
                   RowBox[{"[", 
                    RowBox[{"All", ",", "1"}], "]"}], "]"}], ",", 
                  RowBox[{
                   RowBox[{"(", 
                    RowBox[{"#", ">", "0"}], ")"}], "&"}]}], "]"}], "]"}]}], 
              "]"}], 
             RowBox[{"{", 
              RowBox[{"1", ",", "1"}], "}"}]}]}], "}"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"mt", "=", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{
             RowBox[{"births", "[", 
              RowBox[{"[", 
