Cell[CellGroupData[{

Cell["Distribution of regrowth times (RIF):", "Subsubsection",
 CellChangeTimes->{{3.9403913584301844`*^9, 3.940391366679672*^9}, 
   3.9517462868846817`*^9, {3.960909786568346*^9, 3.960909792004629*^9}, {
