Cell[CellGroupData[{

Cell["\<\
Find the optimal mu that maximizes the p - value of the fit to the \
large-colony mutant number distribution:\
\>", "Subsection",
 CellChangeTimes->{{3.926674713045538*^9, 3.9266747300869446`*^9}, {
  3.9610805497886486`*^9, 
  3.961080568530367*^9}},ExpressionUUID->"e450d41c-fda4-4da0-a6aa-\
a12173b4ed2a"],

Cell[BoxData[{
 RowBox[{"Clear", "[", 
  RowBox[{"RunOnce", ",", "mu"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"RunOnce", "[", "mu_", "]"}], ":=", 
  RowBox[{
   RowBox[{"RunOnce", "[", "mu", "]"}], "=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"pval", ",", "simcfus", ",", "processes"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"SetDirectory", "[", 
       RowBox[{
        RowBox[{"NotebookDirectory", "[", "]"}], 
        "<>", "\"\<\\\\models\\\\STRmutS\>\""}], "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"args", "=", 
       RowBox[{"Table", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"\"\<optimization\>\"", "<>", 
            RowBox[{"ToString", "[", "nn", "]"}]}], ",", 
           RowBox[{"ToString", "[", 
            RowBox[{"vols2", "[", 
             RowBox[{"[", "nn", "]"}], "]"}], "]"}], ",", 
           RowBox[{"ToString", "[", 
            RowBox[{"odinis2", "[", 
             RowBox[{"[", "nn", "]"}], "]"}], "]"}], ",", 
           RowBox[{"ToString", "[", "100", "]"}], ",", 
           RowBox[{"ToString", "[", 
            RowBox[{"tends2", "[", 
             RowBox[{"[", "nn", "]"}], "]"}], "]"}], ",", 
           RowBox[{"ToString", "[", "100", "]"}], ",", 
           RowBox[{"ToString", "[", "odregrowth", "]"}], ",", "\"\<100\>\"", ",", 
           RowBox[{"ToString", "[", 
            RowBox[{"mu", ",", "CForm"}], "]"}], ",", 
           RowBox[{"ToString", "[", 
            RowBox[{"mu", ",", "CForm"}], "]"}], ",", 
           RowBox[{"ToString", "[", "dilf2", "]"}], ",", 
           RowBox[{"(", 
            RowBox[{"\"\<input_params_\>\"", "<>", 
             RowBox[{"ToString", "[", "nn", "]"}], "<>", "\"\<.dat\>\""}], 
            ")"}], ",", "\"\<0.1\>\""}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"nn", ",", 
           RowBox[{"Length", "[", "births2", "]"}]}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"name", "=", 
       RowBox[{"\"\<..\\\\create_processes.exe \
..\\\\turbidostat_evolution_for_Bayesian_many_strains_many_muts_ind_params.\
exe \>\"", "<>", 
        RowBox[{"ToString", "[", 
         RowBox[{"Length", "[", "args", "]"}], "]"}], "<>", "\"\< \>\"", "<>", 
        RowBox[{"ToString", "[", 
         RowBox[{"Length", "[", 
          RowBox[{"args", "[", 
           RowBox[{"[", "1", "]"}], "]"}], "]"}], "]"}], "<>", "\"\< \>\"", "<>", 
        RowBox[{"StringJoin", "[", 
         RowBox[{"Riffle", "[", 
          RowBox[{
           RowBox[{"Flatten", "[", "args", "]"}], ",", "\"\< \>\""}], "]"}], 
         "]"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{"Run", "[", 
        RowBox[{"\"\<powershell -NoExit \>\"", "<>", "name"}], "]"}], "*)"}], 
      "\[IndentingNewLine]", 
      RowBox[{"ret", "=", 
       RowBox[{"RunProcess", "[", 
        RowBox[{"{", 
         RowBox[{"\"\<powershell\>\"", ",", "name"}], "}"}], "]"}]}], ";", 
      " ", 
      RowBox[{"(*", " ", 
       RowBox[{
       "waits", " ", "until", " ", "the", " ", "process", " ", "exits"}], " ",
        "*)"}], "\[IndentingNewLine]", 
      RowBox[{"simcfus", "=", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"ReadList", "[", 
          RowBox[{
           RowBox[{"\"\<strains_optimization\>\"", "<>", 
            RowBox[{"ToString", "[", "n", "]"}], "<>", "\"\<.dat\>\""}], ",", 
           RowBox[{"{", 
            RowBox[{"Number", ",", "Number", ",", "Number", ",", "Number"}], 
            "}"}]}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"n", ",", 
           RowBox[{"Length", "[", "births2", "]"}]}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"SetDirectory", "[", 
       RowBox[{"NotebookDirectory", "[", "]"}], "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"pval", "=", 
       RowBox[{"KolmogorovSmirnovTest", "[", 
        RowBox[{
         RowBox[{"Flatten", "[", 
          RowBox[{"Table", "[", 
           RowBox[{
            RowBox[{"Table", "[", 
             RowBox[{
              RowBox[{"Total", "[", 
               RowBox[{"simcfus", "[", 
                RowBox[{"[", 
                 RowBox[{"k", ",", "i", ",", 
                  RowBox[{"3", ";;"}]}], "]"}], "]"}], "]"}], ",", 
              RowBox[{"{", 
               RowBox[{"i", ",", 
                RowBox[{"Length", "[", 
                 RowBox[{"simcfus", "[", 
                  RowBox[{"[", "k", "]"}], "]"}], "]"}]}], "}"}]}], "]"}], ",", 
            RowBox[{"{", 
             RowBox[{"k", ",", 
              RowBox[{"Length", "[", "simcfus", "]"}]}], "}"}]}], "]"}], 
          "]"}], ",", "cfus"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"Return", "[", 
       RowBox[{"-", "pval"}], "]"}]}]}], "]"}]}]}]}], "Input",
