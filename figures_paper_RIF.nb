             RowBox[{"[", "nn", "]"}], "]"}], "]"}], ",", 
           RowBox[{"ToString", "[", 
            RowBox[{"tends", "[", 
             RowBox[{"[", "nn", "]"}], "]"}], "]"}], ",", 
           RowBox[{"ToString", "[", 
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"tregrowths", "[", 
                RowBox[{"[", "nn", "]"}], "]"}], "\[NotEqual]", 
               "\[Infinity]"}], ",", 
              RowBox[{"tregrowths", "[", 
               RowBox[{"[", "nn", "]"}], "]"}], ",", "tmax"}], "]"}], "]"}], ",", 
