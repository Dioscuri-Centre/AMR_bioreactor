          RowBox[{
           RowBox[{"fc", "<", "fd"}], ",", 
           RowBox[{
            RowBox[{"b", "=", "d"}], ";", 
            RowBox[{"fb", "=", "fd"}]}], ",", 
           RowBox[{
            RowBox[{"a", "=", "c"}], ";", 
            RowBox[{"fa", "=", "fc"}]}]}], "]"}], ";", "\[IndentingNewLine]", 
         RowBox[{"Print", "[", 
          RowBox[{
          "a", ",", "\"\< \>\"", ",", "b", ",", " ", "\"\< fa=\>\"", ",", 
           "fc", ",", "\"\< fb=\>\"", ",", "fb"}], "]"}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"(", 
             RowBox[{"b", "-", "a"}], ")"}], "<", "\[Epsilon]"}], ",", 
           RowBox[{"Break", "[", "]"}]}], "]"}]}], "\[IndentingNewLine]", ",", 
        RowBox[{"{", 
         RowBox[{"n", ",", "10"}], "}"}]}], "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"Return", "[", 
