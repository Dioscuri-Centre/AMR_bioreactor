             RowBox[{"NumberQ", "[", "#1", "]"}], "&"}]}], "]"}], "]"}], ",", 
         RowBox[{"Length", "[", "tregrowths", "]"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"fractions", "=", 
       RowBox[{"Table", "[", 
