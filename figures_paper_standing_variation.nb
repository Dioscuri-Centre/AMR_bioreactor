 RowBox[{"Clear", "[", "RemoveSpikes", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"RemoveSpikes", "[", "d_", "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"diff", "=", 
        RowBox[{"Abs", "[", 
         RowBox[{"Differences", "[", 
          RowBox[{"d", "[", 
           RowBox[{"[", 
            RowBox[{"All", ",", "2"}], "]"}], "]"}], "]"}], "]"}]}], ",", 
       RowBox[{"eps", "=", "0.005"}]}], "}"}], ",", 
     RowBox[{
      RowBox[{"Select", "[", 
       RowBox[{
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"d", "[", 
             RowBox[{"[", "i", "]"}], "]"}], ",", 
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{"i", "<", 
               RowBox[{
                RowBox[{"Length", "[", "d", "]"}], "-", "1"}]}], ",", 
              RowBox[{"If", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{
                  RowBox[{"diff", "[", 
                   RowBox[{"[", 
                    RowBox[{"i", "+", "1"}], "]"}], "]"}], "<", "eps"}], " ", 
                 "&&", " ", 
                 RowBox[{
                  RowBox[{"diff", "[", 
                   RowBox[{"[", "i", "]"}], "]"}], "<", "eps"}]}], ",", 
                "True", ",", "False"}], "]"}], ",", 
              RowBox[{"If", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{"diff", "[", 
                  RowBox[{"[", 
                   RowBox[{"i", "-", "1"}], "]"}], "]"}], "<", "eps"}], ",", 
                "True", ",", "False"}], "]"}]}], "]"}]}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", 
            RowBox[{"Length", "[", "d", "]"}]}], "}"}]}], "]"}], ",", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"#", "[", 
           RowBox[{"[", "2", "]"}], "]"}], ")"}], "&"}]}], "]"}], "[", 
      RowBox[{"[", 
       RowBox[{"All", ",", "1"}], "]"}], "]"}]}], "]"}]}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"Clear", "[", "DispPval", "]"}], "\[IndentingNewLine]", 
