Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"Clear", "[", 
  RowBox[{"RunOnce2", ",", "\[Omega]", ",", "q"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"mu", "=", 
  RowBox[{
   RowBox[{"Interpreter", "[", "\"\<Number\>\"", "]"}], "[", "mutrate", 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"RunOnce2", "[", 
   RowBox[{
    RowBox[{"\[Omega]_", "?", "NumericQ"}], ",", 
    RowBox[{"q_", "?", "NumericQ"}]}], "]"}], ":=", 
  RowBox[{
   RowBox[{"RunOnce2", "[", 
    RowBox[{"\[Omega]", ",", "q"}], "]"}], "=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "pval1", ",", "pval2", ",", "pval3", ",", "fractions", ",", "simcfus", ",",
        "simdist", ",", "tmp", ",", "psurv", ",", "psurvexp", ",", "ret", ",",
        "processes"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{"Return", "[", 
       RowBox[{
        RowBox[{"\[Omega]", "^", "2"}], "+", 
        RowBox[{"q", "^", "2"}]}], "]"}], "*)"}], "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"strains", "=", "2"}], ";", 
      RowBox[{"alleles", "=", "1"}], ";", "\[IndentingNewLine]", 
      RowBox[{"BlockRandom", "[", 
       RowBox[{
        RowBox[{"Do", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{
           RowBox[{"wt", "=", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{
                RowBox[{"births", "[", 
                 RowBox[{"[", 
                  RowBox[{"nn", ",", "1"}], "]"}], "]"}], ",", 
                RowBox[{"births", "[", 
                 RowBox[{"[", 
                  RowBox[{"nn", ",", "1"}], "]"}], "]"}]}], "}"}], ",", 
              RowBox[{"{", 
               RowBox[{"0", ",", "0"}], "}"}]}], "}"}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"it", "=", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{
               RowBox[{"births", "[", 
                RowBox[{"[", 
                 RowBox[{"nn", ",", "1"}], "]"}], "]"}], 
               RowBox[{"{", 
                RowBox[{"1", ",", "1"}], "}"}]}], ",", 
              RowBox[{
               RowBox[{"If", "[", 
                RowBox[{
                 RowBox[{
                  RowBox[{"birthsres", "[", 
                   RowBox[{"[", 
                    RowBox[{"nn", ",", "1"}], "]"}], "]"}], ">", "0"}], ",", 
                 RowBox[{"birthsres", "[", 
                  RowBox[{"[", 
                   RowBox[{"nn", ",", "1"}], "]"}], "]"}], ",", 
                 RowBox[{"RandomChoice", "[", 
                  RowBox[{"Select", "[", 
                   RowBox[{
                    RowBox[{"birthsres", "[", 
                    RowBox[{"[", 
                    RowBox[{"All", ",", "1"}], "]"}], "]"}], ",", 
                    RowBox[{
                    RowBox[{"(", 
                    RowBox[{"#", ">", "0"}], ")"}], "&"}]}], "]"}], "]"}]}], 
                "]"}], 
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"Abs", "[", "q", "]"}], ",", 
                 RowBox[{"Abs", "[", "q", "]"}]}], "}"}]}]}], "}"}]}], ";", 
           " ", "\[IndentingNewLine]", 
           RowBox[{"mt", "=", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{
               RowBox[{"births", "[", 
                RowBox[{"[", 
                 RowBox[{"nn", ",", "1"}], "]"}], "]"}], 
               RowBox[{"{", 
                RowBox[{"1", ",", "1"}], "}"}]}], ",", 
              RowBox[{
               RowBox[{"If", "[", 
                RowBox[{
                 RowBox[{
                  RowBox[{"birthsres", "[", 
                   RowBox[{"[", 
                    RowBox[{"nn", ",", "1"}], "]"}], "]"}], ">", "0"}], ",", 
                 RowBox[{"birthsres", "[", 
                  RowBox[{"[", 
                   RowBox[{"nn", ",", "1"}], "]"}], "]"}], ",", 
                 RowBox[{"RandomChoice", "[", 
                  RowBox[{"Select", "[", 
                   RowBox[{
                    RowBox[{"birthsres", "[", 
                    RowBox[{"[", 
                    RowBox[{"All", ",", "1"}], "]"}], "]"}], ",", 
                    RowBox[{
                    RowBox[{"(", 
                    RowBox[{"#", ">", "0"}], ")"}], "&"}]}], "]"}], "]"}]}], 
                "]"}], 
               RowBox[{"{", 
                RowBox[{"1", ",", "1"}], "}"}]}]}], "}"}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"Export", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"NotebookDirectory", "[", "]"}], 
              "<>", "\"\<\\\\models\\\\STR_filament_lag\\\\input_params_\>\"",
               "<>", 
              RowBox[{"ToString", "[", "nn", "]"}], "<>", "\"\<.dat\>\""}], ",", 
             RowBox[{"Join", "[", 
              RowBox[{
               RowBox[{"{", 
                
                RowBox[{"\"\<CIP\>\"", ",", "\"\<0.66\>\"", ",", "strains", ",",
                  "alleles"}], "}"}], ",", 
               RowBox[{"wt", "[", 
                RowBox[{"[", "1", "]"}], "]"}], ",", 
               RowBox[{"it", "[", 
                RowBox[{"[", "1", "]"}], "]"}], ",", 
               RowBox[{"mt", "[", 
                RowBox[{"[", "1", "]"}], "]"}], ",", 
               RowBox[{"wt", "[", 
                RowBox[{"[", "2", "]"}], "]"}], ",", 
               RowBox[{"it", "[", 
                RowBox[{"[", "2", "]"}], "]"}], ",", 
               RowBox[{"mt", "[", 
                RowBox[{"[", "2", "]"}], "]"}], ",", 
               RowBox[{"{", 
                RowBox[{"1", ",", "1"}], "}"}], ",", 
               RowBox[{"{", "\"\<end\>\"", "}"}]}], "]"}], 
             ",", "\"\<Table\>\""}], "]"}]}], "\[IndentingNewLine]", ",", 
          RowBox[{"{", 
           RowBox[{"nn", ",", 
            RowBox[{"Length", "[", "vols", "]"}]}], "}"}]}], "]"}], ",", 
        RowBox[{"RandomSeeding", "\[Rule]", "123"}]}], "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"SetDirectory", "[", 
       RowBox[{
        RowBox[{"NotebookDirectory", "[", "]"}], 
        "<>", "\"\<\\\\models\\\\STR_filament_lag\>\""}], "]"}], ";", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"args", "=", 
       RowBox[{"Table", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"\"\<optimization_\>\"", "<>", 
            RowBox[{"ToString", "[", "nn", "]"}]}], ",", 
           RowBox[{"ToString", "[", 
            RowBox[{"vols", "[", 
             RowBox[{"[", "nn", "]"}], "]"}], "]"}], ",", 
           RowBox[{"ToString", "[", 
            RowBox[{"odinis", "[", 
             RowBox[{"[", "nn", "]"}], "]"}], "]"}], ",", 
           RowBox[{"ToString", "[", 
            RowBox[{"ainjs", "[", 
             RowBox[{"[", "nn", "]"}], "]"}], "]"}], ",", 
           RowBox[{"ToString", "[", 
            RowBox[{"tends", "[", 
             RowBox[{"[", "nn", "]"}], "]"}], "]"}], ",", 
           RowBox[{"ToString", "[", 
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"tregrowths", "[", 
                RowBox[{"[", "nn", "]"}], "]"}], "\[NotEqual]", 
               "\[Infinity]"}], ",", 
              RowBox[{"tregrowths", "[", 
               RowBox[{"[", "nn", "]"}], "]"}], ",", "tmax"}], "]"}], "]"}], ",", 
           RowBox[{"ToString", "[", "odregrowth", "]"}], ",", "\"\<300\>\"", ",", 
           RowBox[{"ToString", "[", 
            RowBox[{"mu", ",", "CForm"}], "]"}], ",", 
           RowBox[{"ToString", "[", 
            RowBox[{"mu", ",", "CForm"}], "]"}], ",", 
           RowBox[{"ToString", "[", "dilf", "]"}], ",", 
           RowBox[{"(", 
            RowBox[{"\"\<input_params_\>\"", "<>", 
             RowBox[{"ToString", "[", "nn", "]"}], "<>", "\"\<.dat\>\""}], 
            ")"}], ",", "\"\<0.1\>\"", ",", 
           RowBox[{"ToString", "[", 
            RowBox[{"Abs", "[", "\[Omega]", "]"}], "]"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"nn", ",", 
           RowBox[{"Length", "[", "vols", "]"}]}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"name", "=", 
       RowBox[{"\"\<..\\\\create_processes.exe \
..\\\\turbidostat_evolution_for_Bayesian_many_strains_many_muts_interm_state_\
ind_params_v2.exe \>\"", "<>", 
        RowBox[{"ToString", "[", 
         RowBox[{"Length", "[", "args", "]"}], "]"}], "<>", "\"\< \>\"", "<>", 
        RowBox[{"ToString", "[", 
         RowBox[{"Length", "[", 
          RowBox[{"args", "[", 
           RowBox[{"[", "1", "]"}], "]"}], "]"}], "]"}], "<>", "\"\< \>\"", "<>", 
        RowBox[{"StringJoin", "[", 
         RowBox[{"Riffle", "[", 
          RowBox[{
           RowBox[{"Flatten", "[", "args", "]"}], ",", "\"\< \>\""}], "]"}], 
         "]"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{"Run", "[", 
        RowBox[{"\"\<powershell -NoExit \>\"", "<>", "name"}], "]"}], "*)"}], 
      "\[IndentingNewLine]", 
      RowBox[{"ret", "=", 
       RowBox[{"RunProcess", "[", 
        RowBox[{"{", 
         RowBox[{"\"\<powershell\>\"", ",", "name"}], "}"}], "]"}]}], ";", 
      " ", 
      RowBox[{"(*", " ", 
       RowBox[{
       "waits", " ", "until", " ", "the", " ", "process", " ", "exits"}], " ",
        "*)"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"SetDirectory", "[", 
       RowBox[{"NotebookDirectory", "[", "]"}], "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"simdist", "=", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"Import", "[", 
          RowBox[{
           
           RowBox[{"\"\<models\\\\STR_filament_lag\\\\distribution_\
optimization_\>\"", "<>", 
            RowBox[{"ToString", "[", "nn", "]"}], "<>", "\"\<.dat\>\""}], 
           ",", "\"\<Table\>\""}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"nn", ",", 
           RowBox[{"Length", "[", "births", "]"}]}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"tmp", "=", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"NumberQ", "[", 
              RowBox[{"#", "[", 
               RowBox[{"[", "2", "]"}], "]"}], "]"}], ",", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"#", "[", 
                RowBox[{"[", "1", "]"}], "]"}], ",", 
               RowBox[{
                RowBox[{"#", "[", 
                 RowBox[{"[", "2", "]"}], "]"}], "-", 
                RowBox[{"ainjs", "[", 
                 RowBox[{"[", "i", "]"}], "]"}]}], ",", 
               RowBox[{"#", "[", 
                RowBox[{"[", "3", "]"}], "]"}], ",", 
               RowBox[{
                RowBox[{"#", "[", 
                 RowBox[{"[", "4", "]"}], "]"}], "-", 
                RowBox[{"ainjs", "[", 
                 RowBox[{"[", "i", "]"}], "]"}]}]}], "}"}], ",", "#"}], "]"}],
            "&"}], "/@", 
          RowBox[{"Select", "[", 
           RowBox[{
            RowBox[{"simdist", "[", 
             RowBox[{"[", "i", "]"}], "]"}], ",", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{
               RowBox[{"Abs", "[", 
                RowBox[{
                 RowBox[{"#", "[", 
                  RowBox[{"[", "3", "]"}], "]"}], "-", 
                 RowBox[{"tfirstthr", "[", 
                  RowBox[{"[", "i", "]"}], "]"}]}], "]"}], "<", "0.2"}], 
              ")"}], "&"}]}], "]"}]}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", 
           RowBox[{"Length", "[", "simdist", "]"}]}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"tmp", "=", 
       RowBox[{"Flatten", "[", 
        RowBox[{"tmp", ",", "1"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"pval2", "=", 
       RowBox[{"KolmogorovSmirnovTest", "[", 
        RowBox[{
         RowBox[{"Select", "[", 
          RowBox[{
           RowBox[{"tmp", "\[LeftDoubleBracket]", 
            RowBox[{"All", ",", "2"}], "\[RightDoubleBracket]"}], ",", 
           RowBox[{
            RowBox[{"NumberQ", "[", "#1", "]"}], "&"}]}], "]"}], ",", 
         RowBox[{"Select", "[", 
          RowBox[{
           RowBox[{"tregrowths", "-", "ainjs"}], ",", 
           RowBox[{
            RowBox[{"NumberQ", "[", "#1", "]"}], "&"}]}], "]"}]}], "]"}]}], ";",
       "\[IndentingNewLine]", 
      RowBox[{"pval1", "=", 
       RowBox[{"FisherExactTest", "[", 
        RowBox[{
         RowBox[{"Length", "[", 
          RowBox[{"Select", "[", 
           RowBox[{"tmp", ",", 
            RowBox[{
             RowBox[{"NumberQ", "[", 
              RowBox[{
              "#1", "\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}], 
              "]"}], "&"}]}], "]"}], "]"}], ",", 
         RowBox[{"Length", "[", "tmp", "]"}], ",", 
         RowBox[{"Length", "[", 
          RowBox[{"Select", "[", 
           RowBox[{"tregrowths", ",", 
            RowBox[{
             RowBox[{"NumberQ", "[", "#1", "]"}], "&"}]}], "]"}], "]"}], ",", 
         RowBox[{"Length", "[", "tregrowths", "]"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"fractions", "=", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"Min", "[", 
            RowBox[{
             RowBox[{"1.", 
              RowBox[{
               RowBox[{"#", "[", 
                RowBox[{"[", "7", "]"}], "]"}], "/", 
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"#", "[", 
                  RowBox[{"[", "10", "]"}], "]"}], "+", 
                 RowBox[{"#", "[", 
                  RowBox[{"[", "7", "]"}], "]"}]}], ")"}]}]}], ",", 
             RowBox[{"1.", 
              RowBox[{
               RowBox[{"#", "[", 
                RowBox[{"[", "10", "]"}], "]"}], "/", 
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"#", "[", 
                  RowBox[{"[", "10", "]"}], "]"}], "+", 
                 RowBox[{"#", "[", 
                  RowBox[{"[", "7", "]"}], "]"}]}], ")"}]}]}]}], "]"}], "&"}],
           "/@", 
          RowBox[{"Select", "[", 
           RowBox[{
            RowBox[{"simdist", "[", 
             RowBox[{"[", "i", "]"}], "]"}], ",", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{
               RowBox[{
                RowBox[{"#", "[", 
                 RowBox[{"[", "7", "]"}], "]"}], "+", 
                RowBox[{"#", "[", 
                 RowBox[{"[", "10", "]"}], "]"}]}], ">", "0"}], ")"}], 
             "&"}]}], "]"}]}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", 
           RowBox[{"Length", "[", "simdist", "]"}]}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"pval3", "=", 
       RowBox[{"KolmogorovSmirnovTest", "[", 
        RowBox[{
         RowBox[{"Round", "[", 
          RowBox[{
           RowBox[{"Flatten", "[", "fractions", "]"}], ",", "ksround"}], 
          "]"}], ",", 
