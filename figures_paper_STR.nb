               RowBox[{"#", "<", "0.1"}], ")"}], "&"}]}], "]"}], "]"}], "/", 
          RowBox[{"Length", "[", "experfractions", "]"}]}]}]}], "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Print", "[", 
       RowBox[{"\"\<fraction below 0.1 (sim):\>\"", ",", 
        RowBox[{"1.", 
