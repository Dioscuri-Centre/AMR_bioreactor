Cell[BoxData[
 RowBox[{"Do", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"pl", "=", 
     RowBox[{"Show", "[", 
      RowBox[{
       RowBox[{"ListDensityPlot", "[", 
        RowBox[{
