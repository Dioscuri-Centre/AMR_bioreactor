          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"0", ",", "20"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"0", ",", "0.1"}], "}"}]}], "}"}]}]}], "]"}], ",", 
       RowBox[{"ListPlot", "[", 
        RowBox[{
         RowBox[{"dataSTR3", "[", 
          RowBox[{"[", 
           RowBox[{"k", ",", "\"\<ods\>\""}], "]"}], "]"}], ",", 
         RowBox[{"Joined", "\[Rule]", "True"}], ",", 
