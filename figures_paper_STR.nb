   RowBox[{"Interpreter", "[", "\"\<Number\>\"", "]"}], "[", "mutrate", 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"strains", "=", "2"}], ";", 
