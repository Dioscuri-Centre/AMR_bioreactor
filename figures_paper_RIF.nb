               RowBox[{"birthsres", "[", 
                RowBox[{"[", 
                 RowBox[{"nn", ",", "1"}], "]"}], "]"}], ",", 
               RowBox[{"RandomChoice", "[", 
                RowBox[{"Select", "[", 
                 RowBox[{
                  RowBox[{"birthsres", "[", 
                   RowBox[{"[", 
                    RowBox[{"All", ",", "1"}], "]"}], "]"}], ",", 
                  RowBox[{
                   RowBox[{"(", 
                    RowBox[{"#", ">", "0"}], ")"}], "&"}]}], "]"}], "]"}]}], 
              "]"}], 
             RowBox[{"{", 
              RowBox[{"1", ",", "1"}], "}"}]}]}], "}"}]}], ";", 
         "\[IndentingNewLine]", "\[IndentingNewLine]", 
         RowBox[{"Export", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"NotebookDirectory", "[", "]"}], 
            "<>", "\"\<\\\\models\\\\RIF_lag\\\\input_params_\>\"", "<>", 
            RowBox[{"ToString", "[", "nn", "]"}], "<>", "\"\<.dat\>\""}], ",", 
           RowBox[{"Join", "[", 
