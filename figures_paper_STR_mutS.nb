 RowBox[{
  RowBox[{
   RowBox[{"strains", "=", "2"}], ";", 
   RowBox[{"alleles", "=", "1"}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"BlockRandom", "[", 
  RowBox[{
   RowBox[{"Do", "[", "\[IndentingNewLine]", 
    RowBox[{"(*", " ", 
     RowBox[{
     "parent", " ", "strains", " ", "before", " ", "and", " ", "after", " ", 
