 RowBox[{
  RowBox[{
   RowBox[{"NaiveMinimization", "[", 
    RowBox[{"fun_", ",", "a0_", ",", "b0_", ",", "\[Epsilon]_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "a", ",", "b", ",", "c", ",", "d", ",", "fa", ",", "fb", ",", "fc", ",",
        "fd", ",", 
       RowBox[{"gr", "=", 
        RowBox[{"1.", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"Sqrt", "[", "5", "]"}], "+", "1"}], ")"}], "/", 
          "2"}]}]}]}], "}"}], ",", 
     RowBox[{
      RowBox[{"a", "=", 
       RowBox[{"1.", "a0"}]}], ";", 
      RowBox[{"b", "=", 
       RowBox[{"1.", "b0"}]}], ";", 
      RowBox[{"Do", "[", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{"c", "=", 
          RowBox[{"b", "-", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"b", "-", "a"}], ")"}], "/", "gr"}]}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"d", "=", 
          RowBox[{"a", "+", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"b", "-", "a"}], ")"}], "/", "gr"}]}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"fa", "=", 
          RowBox[{"fun", "[", "a", "]"}]}], ";", 
         RowBox[{"fb", "=", 
          RowBox[{"fun", "[", "b", "]"}]}], ";", 
         RowBox[{"fc", "=", 
          RowBox[{"fun", "[", "c", "]"}]}], ";", 
         RowBox[{"fd", "=", 
          RowBox[{"fun", "[", "d", "]"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"fc", "<", "fd"}], ",", 
           RowBox[{
            RowBox[{"b", "=", "d"}], ";", 
            RowBox[{"fb", "=", "fd"}]}], ",", 
           RowBox[{
            RowBox[{"a", "=", "c"}], ";", 
            RowBox[{"fa", "=", "fc"}]}]}], "]"}], ";", "\[IndentingNewLine]", 
         RowBox[{"Print", "[", 
          RowBox[{
          "a", ",", "\"\< \>\"", ",", "b", ",", " ", "\"\< fa=\>\"", ",", 
           "fc", ",", "\"\< fb=\>\"", ",", "fb"}], "]"}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"(", 
             RowBox[{"b", "-", "a"}], ")"}], "<", "\[Epsilon]"}], ",", 
           RowBox[{"Break", "[", "]"}]}], "]"}]}], "\[IndentingNewLine]", ",", 
        RowBox[{"{", 
         RowBox[{"n", ",", "10"}], "}"}]}], "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"Return", "[", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"a", "+", "b"}], ")"}], "/", "2"}], "]"}]}]}], "]"}]}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
