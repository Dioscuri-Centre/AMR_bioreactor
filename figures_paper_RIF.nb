Cell[CellGroupData[{

Cell["Optimize \[Mu] to get the best fit to CFUs:", "Section",
 CellChangeTimes->{{3.931502468037775*^9, 3.931502478994251*^9}, {
  3.95094358532786*^9, 3.950943601719122*^9}, {3.960826013701969*^9, 
  3.960826018184452*^9}},ExpressionUUID->"4afd14e7-a54c-47d4-86cf-\
9873e57d47be"],

Cell[BoxData[{
 RowBox[{"Clear", "[", "RunOnceMultNoLag", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"RunOnceMultNoLag", "[", "mu_", "]"}], ":=", 
  RowBox[{
   RowBox[{"RunOnceMultNoLag", "[", "mu", "]"}], "=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"pval", ",", "simcfus", ",", "processes"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"SetDirectory", "[", 
        RowBox[{
         RowBox[{"NotebookDirectory", "[", "]"}], 
         "<>", "\"\<\\\\models\\\\RIF_mult\>\""}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"args", "=", 
        RowBox[{"Table", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"\"\<optimization\>\"", "<>", 
             RowBox[{"ToString", "[", "nn", "]"}]}], ",", 
            RowBox[{"ToString", "[", 
             RowBox[{"vols2", "[", 
              RowBox[{"[", "nn", "]"}], "]"}], "]"}], ",", 
            RowBox[{"ToString", "[", 
             RowBox[{"odinis2", "[", 
              RowBox[{"[", "nn", "]"}], "]"}], "]"}], ",", 
            RowBox[{"ToString", "[", "100", "]"}], ",", 
            RowBox[{"ToString", "[", 
             RowBox[{"tends2", "[", 
              RowBox[{"[", "nn", "]"}], "]"}], "]"}], ",", 
            RowBox[{"ToString", "[", "100", "]"}], ",", 
            RowBox[{"ToString", "[", "odregrowth2", "]"}], 
            ",", "\"\< 100 \>\"", ",", 
            RowBox[{"ToString", "[", 
             RowBox[{"mu", ",", "CForm"}], "]"}], ",", 
            RowBox[{"ToString", "[", 
             RowBox[{"mu", ",", "CForm"}], "]"}], ",", 
            RowBox[{"ToString", "[", "dilf2", "]"}], ",", 
            RowBox[{"(", 
             RowBox[{"\"\<input_params_\>\"", "<>", 
              RowBox[{"ToString", "[", "nn", "]"}], "<>", "\"\<.dat\>\""}], 
             ")"}], ",", "\"\< 0.1 \>\""}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"nn", ",", 
            RowBox[{"Length", "[", "births2", "]"}]}], "}"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"name", "=", 
        RowBox[{"\"\<..\\\\create_processes.exe \
..\\\\turbidostat_evolution_for_Bayesian_many_strains_many_muts_ind_params.\
exe \>\"", "<>", 
         RowBox[{"ToString", "[", 
          RowBox[{"Length", "[", "args", "]"}], "]"}], "<>", "\"\< \>\"", "<>", 
         RowBox[{"ToString", "[", 
          RowBox[{"Length", "[", 
           RowBox[{"args", "[", 
            RowBox[{"[", "1", "]"}], "]"}], "]"}], "]"}], "<>", "\"\< \>\"", "<>", 
         RowBox[{"StringJoin", "[", 
          RowBox[{"Riffle", "[", 
           RowBox[{
            RowBox[{"Flatten", "[", "args", "]"}], ",", "\"\< \>\""}], "]"}], 
          "]"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"ret", "=", 
        RowBox[{"RunProcess", "[", 
         RowBox[{"{", 
          RowBox[{"\"\<powershell\>\"", ",", "name"}], "}"}], "]"}]}], ";"}], 
      " ", 
      RowBox[{"(*", " ", 
       RowBox[{
       "waits", " ", "until", " ", "the", " ", "process", " ", "exits"}], " ",
        "*)"}], "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{"Run", "[", 
         RowBox[{"\"\<powershell -NoExit \>\"", "<>", "name"}], "]"}], ";"}], 
       "*)"}], ";", "\[IndentingNewLine]", 
      RowBox[{"simcfus", "=", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"ReadList", "[", 
          RowBox[{
           RowBox[{"\"\<strains_optimization\>\"", "<>", 
            RowBox[{"ToString", "[", "n", "]"}], "<>", "\"\<.dat\>\""}], ",", 
           RowBox[{"Table", "[", 
            RowBox[{"Number", ",", 
             RowBox[{"{", 
              RowBox[{"strains", " ", 
               RowBox[{"(", 
                RowBox[{"alleles", "+", "1"}], ")"}]}], "}"}]}], "]"}]}], 
          "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"n", ",", 
           RowBox[{"Length", "[", "births2", "]"}]}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"SetDirectory", "[", 
       RowBox[{"NotebookDirectory", "[", "]"}], "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"pval", "=", 
       RowBox[{"KolmogorovSmirnovTest", "[", 
        RowBox[{
         RowBox[{"Flatten", "[", 
          RowBox[{"Table", "[", 
           RowBox[{
            RowBox[{"Table", "[", 
             RowBox[{
              RowBox[{"Total", "[", 
               RowBox[{"simcfus", "[", 
                RowBox[{"[", 
                 RowBox[{"k", ",", "i", ",", 
                  RowBox[{"3", ";;"}]}], "]"}], "]"}], "]"}], ",", 
              RowBox[{"{", 
               RowBox[{"i", ",", 
                RowBox[{"Length", "[", 
                 RowBox[{"simcfus", "[", 
                  RowBox[{"[", "k", "]"}], "]"}], "]"}]}], "}"}]}], "]"}], ",", 
            RowBox[{"{", 
             RowBox[{"k", ",", 
              RowBox[{"Length", "[", "simcfus", "]"}]}], "}"}]}], "]"}], 
          "]"}], ",", "cfus"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"Return", "[", 
       RowBox[{"-", "pval"}], "]"}]}]}], "]"}]}]}]}], "Input",
 CellChangeTimes->{{3.950872098096199*^9, 3.950872246454584*^9}, {
   3.950872498308323*^9, 3.950872528526459*^9}, {3.9509405977067623`*^9, 
