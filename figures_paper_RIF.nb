           RowBox[{"(", 
            RowBox[{"\"\<input_params_\>\"", "<>", 
             RowBox[{"ToString", "[", "nn", "]"}], "<>", "\"\<.dat\>\""}], ")"}]\
, ",", "\"\< 0.1 \>\"", ",", 
           RowBox[{"ToString", "[", 
            RowBox[{"Abs", "[", "\[Omega]", "]"}], "]"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"nn", ",", 
           RowBox[{"Length", "[", "births", "]"}]}], "}"}]}], "]"}]}], ";", 
      " ", 
      RowBox[{"(*", " ", 
       RowBox[{"tolerance", ",", " ", "omega"}], " ", "*)"}], 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"name", "=", 
       RowBox[{"\"\<..\\\\create_processes.exe \
..\\\\turbidostat_evolution_for_Bayesian_many_strains_many_muts_interm_state_\
ind_params_v2.exe \>\"", "<>", 
        RowBox[{"ToString", "[", 
         RowBox[{"Length", "[", "args", "]"}], "]"}], "<>", "\"\< \>\"", "<>", 
        RowBox[{"ToString", "[", 
         RowBox[{"Length", "[", 
          RowBox[{"args", "[", 
           RowBox[{"[", "1", "]"}], "]"}], "]"}], "]"}], "<>", "\"\< \>\"", "<>", 
        RowBox[{"StringJoin", "[", 
