       "mutant", " ", "strains", " ", "before", " ", "and", " ", "after", " ",
         "the", " ", "antibiotic"}], " ", "*)"}], "\[IndentingNewLine]", 
      RowBox[{"mt", "=", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"births", "[", 
           RowBox[{"[", 
