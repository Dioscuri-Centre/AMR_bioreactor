Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"mutrate", "=", "\"\<6.2e-9\>\""}], ";"}], "  ", 
  RowBox[{"(*", " ", 
   RowBox[{
   "this", " ", "value", " ", "comes", " ", "from", " ", "the", " ", 
    "previous", " ", "model", " ", "and", " ", "the", " ", "fluctuation", " ",
     "test", " ", "result"}], " ", "*)"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"lagrate", "=", "\"\<0.04\>\""}], " ", ";"}], " ", 
  RowBox[{"(*", " ", 
   RowBox[{
   "this", " ", "must", " ", "be", " ", "experimentally", " ", "chosen", " ", 
    "to", " ", "give", " ", "the", " ", "best", " ", "fit"}], " ", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"intgrfraction", "=", "0.6"}], ";"}], " ", 
  RowBox[{"(*", " ", 
   RowBox[{
   "this", " ", "must", " ", "be", " ", "experimentally", " ", "chosen", " ", 
    "to", " ", "give", " ", "the", " ", "best", " ", "fit"}], " ", "*)"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"mu", "=", 
  RowBox[{
   RowBox[{"Interpreter", "[", "\"\<Number\>\"", "]"}], "[", "mutrate", 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"strains", "=", "2"}], ";", 
  RowBox[{"alleles", "=", "1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"mutprobs", "=", 
   RowBox[{"{", 
    RowBox[{"1", ",", "1"}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"BlockRandom", "[", 
  RowBox[{"Do", "[", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "parent", " ", "strains", " ", "before", " ", "and", " ", "after", " ", 
     "the", " ", "antibiotic"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"wt", "=", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"births", "[", 
          RowBox[{"[", 
           RowBox[{"nn", ",", "1"}], "]"}], "]"}], 
         RowBox[{"{", 
          RowBox[{"1", ",", "1"}], "}"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"0", ",", "0"}], "}"}]}], "}"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"(*", " ", 
      RowBox[{
      "intermediate", " ", "strains", " ", "before", " ", "and", " ", "after",
        " ", "the", " ", "antibiotics"}], "*)"}], "\[IndentingNewLine]", 
     RowBox[{"it", "=", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"births", "[", 
          RowBox[{"[", 
           RowBox[{"nn", ",", "1"}], "]"}], "]"}], 
         RowBox[{"{", 
          RowBox[{"1", ",", "1"}], "}"}]}], ",", 
        RowBox[{"intgrfraction", " ", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"birthsres", "[", 
             RowBox[{"[", 
              RowBox[{"nn", ",", "1"}], "]"}], "]"}], ">", "0"}], ",", 
           RowBox[{"birthsres", "[", 
            RowBox[{"[", 
             RowBox[{"nn", ",", "1"}], "]"}], "]"}], ",", 
           RowBox[{"RandomChoice", "[", 
            RowBox[{"Select", "[", 
             RowBox[{
              RowBox[{"birthsres", "[", 
               RowBox[{"[", 
                RowBox[{"All", ",", "1"}], "]"}], "]"}], ",", 
              RowBox[{
               RowBox[{"(", 
                RowBox[{"#", ">", "0"}], ")"}], "&"}]}], "]"}], "]"}]}], 
          "]"}], 
         RowBox[{"{", 
          RowBox[{"1", ",", "1"}], "}"}]}]}], "}"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"(*", " ", 
      RowBox[{
      "mutant", " ", "strains", " ", "before", " ", "and", " ", "after", " ", 
       "the", " ", "antibiotic"}], " ", "*)"}], "\[IndentingNewLine]", 
     RowBox[{"mt", "=", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"births", "[", 
          RowBox[{"[", 
           RowBox[{"nn", ",", "1"}], "]"}], "]"}], 
         RowBox[{"{", 
          RowBox[{"1", ",", "1"}], "}"}]}], ",", 
        RowBox[{
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"birthsres", "[", 
             RowBox[{"[", 
              RowBox[{"nn", ",", "1"}], "]"}], "]"}], ">", "0"}], ",", 
           RowBox[{"birthsres", "[", 
            RowBox[{"[", 
             RowBox[{"nn", ",", "1"}], "]"}], "]"}], ",", 
           RowBox[{"RandomChoice", "[", 
            RowBox[{"Select", "[", 
             RowBox[{
              RowBox[{"birthsres", "[", 
               RowBox[{"[", 
                RowBox[{"All", ",", "1"}], "]"}], "]"}], ",", 
