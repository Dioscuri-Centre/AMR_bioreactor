         RowBox[{"ColorFunction", "\[Rule]", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"RGBColor", "[", 
             RowBox[{
              RowBox[{"Max", "[", 
               RowBox[{"0", ",", 
                RowBox[{"1", "-", 
                 RowBox[{"2", "#"}]}]}], "]"}], ",", "1", ",", 
              RowBox[{"Max", "[", 
