              RowBox[{"cfubindata", "[", 
               RowBox[{"[", "2", "]"}], "]"}]}], "}"}], ",", "\"\<PDF\>\"", ",", 
            RowBox[{"ChartStyle", "\[Rule]", "Gray"}]}], "]"}], ",", 
          RowBox[{"SmoothHistogram", "[", 
