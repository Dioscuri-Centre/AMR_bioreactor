Cell[CellGroupData[{

Cell["\<\
For comparison, let us find the optimal \[Mu] that maximizes the p - value \
for the mutant number distribution when colonies of all sizes (small and \
large) are included:\
\>", "Subsection",
 CellChangeTimes->{{3.926674713045538*^9, 3.9266747300869446`*^9}, {
  3.9325609384764833`*^9, 3.9325609602003403`*^9}, {3.9610339932199383`*^9, 
  3.9610340289738903`*^9}},ExpressionUUID->"6f3b951a-010a-47a4-8de4-\
15f817025a17"],

Cell[BoxData[{
 RowBox[{"Clear", "[", 
  RowBox[{"RunOnce", ",", "mu"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"RunOnce", "[", "mu_", "]"}], ":=", 
  RowBox[{
   RowBox[{"RunOnce", "[", "mu", "]"}], "=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"pval", ",", "simcfus", ",", "processes"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"SetDirectory", "[", 
       RowBox[{
        RowBox[{"NotebookDirectory", "[", "]"}], 
        "<>", "\"\<\\\\models\\\\STR\>\""}], "]"}], ";", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"args", "=", 
       RowBox[{"Table", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"\"\<optimization\>\"", "<>", 
            RowBox[{"ToString", "[", "nn", "]"}]}], ",", 
           RowBox[{"ToString", "[", 
            RowBox[{"vols2", "[", 
             RowBox[{"[", "nn", "]"}], "]"}], "]"}], ",", 
           RowBox[{"ToString", "[", 
            RowBox[{"odinis2", "[", 
             RowBox[{"[", "nn", "]"}], "]"}], "]"}], ",", 
           RowBox[{"ToString", "[", "100", "]"}], ",", 
           RowBox[{"ToString", "[", 
            RowBox[{"tends2", "[", 
             RowBox[{"[", "nn", "]"}], "]"}], "]"}], ",", 
           RowBox[{"ToString", "[", "100", "]"}], ",", 
           RowBox[{"ToString", "[", "odregrowth", "]"}], ",", "\"\<100\>\"", ",", 
           RowBox[{"ToString", "[", 
            RowBox[{"mu", ",", "CForm"}], "]"}], ",", 
           RowBox[{"ToString", "[", 
            RowBox[{"mu", ",", "CForm"}], "]"}], ",", 
           RowBox[{"ToString", "[", "dilf2", "]"}], ",", 
           RowBox[{"(", 
            RowBox[{"\"\<input_params_\>\"", "<>", 
             RowBox[{"ToString", "[", "nn", "]"}], "<>", "\"\<.dat\>\""}], 
            ")"}], ",", "\"\<0.1\>\""}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"nn", ",", 
           RowBox[{"Length", "[", "births2", "]"}]}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"name", "=", 
       RowBox[{"\"\<..\\\\create_processes.exe \
..\\\\turbidostat_evolution_for_Bayesian_many_strains_many_muts_ind_params.\
exe \>\"", "<>", 
        RowBox[{"ToString", "[", 
         RowBox[{"Length", "[", "args", "]"}], "]"}], "<>", "\"\< \>\"", "<>", 
        RowBox[{"ToString", "[", 
         RowBox[{"Length", "[", 
          RowBox[{"args", "[", 
           RowBox[{"[", "1", "]"}], "]"}], "]"}], "]"}], "<>", "\"\< \>\"", "<>", 
        RowBox[{"StringJoin", "[", 
         RowBox[{"Riffle", "[", 
          RowBox[{
           RowBox[{"Flatten", "[", "args", "]"}], ",", "\"\< \>\""}], "]"}], 
         "]"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{"Run", "[", 
        RowBox[{"\"\<powershell -NoExit \>\"", "<>", "name"}], "]"}], "*)"}], 
      "\[IndentingNewLine]", 
      RowBox[{"ret", "=", 
       RowBox[{"RunProcess", "[", 
        RowBox[{"{", 
         RowBox[{"\"\<powershell\>\"", ",", "name"}], "}"}], "]"}]}], ";", 
      " ", 
      RowBox[{"(*", " ", 
       RowBox[{
       "waits", " ", "until", " ", "the", " ", "process", " ", "exits"}], " ",
        "*)"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"simcfus", "=", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"ReadList", "[", 
          RowBox[{
           RowBox[{"\"\<strains_optimization\>\"", "<>", 
            RowBox[{"ToString", "[", "n", "]"}], "<>", "\"\<.dat\>\""}], ",", 
           RowBox[{"{", 
            RowBox[{"Number", ",", "Number", ",", "Number", ",", "Number"}], 
            "}"}]}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"n", ",", 
           RowBox[{"Length", "[", "births2", "]"}]}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"SetDirectory", "[", 
       RowBox[{"NotebookDirectory", "[", "]"}], "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"pval", "=", 
       RowBox[{"KolmogorovSmirnovTest", "[", 
        RowBox[{
         RowBox[{"Flatten", "[", 
          RowBox[{"Table", "[", 
           RowBox[{
            RowBox[{"Table", "[", 
             RowBox[{
              RowBox[{"Total", "[", 
               RowBox[{"simcfus", "[", 
                RowBox[{"[", 
                 RowBox[{"k", ",", "i", ",", 
                  RowBox[{"3", ";;"}]}], "]"}], "]"}], "]"}], ",", 
              RowBox[{"{", 
               RowBox[{"i", ",", 
                RowBox[{"Length", "[", 
                 RowBox[{"simcfus", "[", 
                  RowBox[{"[", "k", "]"}], "]"}], "]"}]}], "}"}]}], "]"}], ",", 
            RowBox[{"{", 
             RowBox[{"k", ",", 
              RowBox[{"Length", "[", "simcfus", "]"}]}], "}"}]}], "]"}], 
          "]"}], ",", "cfusall"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"Return", "[", 
       RowBox[{"-", "pval"}], "]"}]}]}], "]"}]}]}]}], "Input",
 CellChangeTimes->{{3.931856547758862*^9, 3.931856548714163*^9}, {
