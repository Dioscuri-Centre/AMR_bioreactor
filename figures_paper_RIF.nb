        RowBox[{"NotebookDirectory", "[", "]"}], 
        "<>", "\"\<\\\\models\\\\RIF_lag\>\""}], "]"}], ";", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"args", "=", 
       RowBox[{"Table", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"\"\<optimization_\>\"", "<>", 
            RowBox[{"ToString", "[", "nn", "]"}]}], ",", 
           RowBox[{"ToString", "[", 
            RowBox[{"vols", "[", 
             RowBox[{"[", "nn", "]"}], "]"}], "]"}], ",", 
           RowBox[{"ToString", "[", 
            RowBox[{"odinis", "[", 
             RowBox[{"[", "nn", "]"}], "]"}], "]"}], ",", 
