           RowBox[{"[", "2", "]"}], "]"}], ",", 
          RowBox[{"{", "\"\<end\>\"", "}"}]}], "]"}], ",", "\"\<Table\>\""}], 
       "]"}]}], "\[IndentingNewLine]", ",", 
