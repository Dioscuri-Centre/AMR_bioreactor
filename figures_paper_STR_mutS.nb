Cell[CellGroupData[{

Cell["\<\
Now optimize \[Omega] and q. The values are then copied manually to the code \
above.\
\>", "Subsection",
 CellChangeTimes->{{3.927129216600164*^9, 3.92712922929166*^9}, {
  3.961081391532007*^9, 
