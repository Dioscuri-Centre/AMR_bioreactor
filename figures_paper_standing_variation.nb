          RowBox[{"Darker", "[", "Green", "]"}]}], ",", 
         RowBox[{"Filling", "->", "Bottom"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"grexp", "=", 
