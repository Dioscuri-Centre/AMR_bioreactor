         RowBox[{"DataRange", "\[Rule]", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"0", ",", "20"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"0", ",", "0.1"}], "}"}]}], "}"}]}]}], "]"}], ",", 
       RowBox[{"ListPlot", "[", 
        RowBox[{
         RowBox[{"dataCIP", "[", 
          RowBox[{"[", 
