Cell[CellGroupData[{

Cell["\<\
Phenotypic lag model for STR with filamentation. One resistant allele. 
Mixed strains AD30 and AD30YFP .\
\>", "Section",
 CellChangeTimes->{{3.8844400597703557`*^9, 3.884440069902989*^9}, {
   3.884440118085515*^9, 3.884440134255271*^9}, {3.884686417720921*^9, 
   3.88468641808165*^9}, {3.919265027500503*^9, 3.919265030408886*^9}, {
   3.927771535532068*^9, 3.927771537075163*^9}, 3.927771570929431*^9, {
   3.931858184900466*^9, 3.931858185313074*^9}, {3.9574954687706184`*^9, 
   3.9574954714933395`*^9}, 
   3.9610343366024647`*^9},ExpressionUUID->"96cd8396-e2d9-4403-9ff7-\
2dfc3066041b"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"mutrate", "=", "\"\<1.6e-10\>\""}], ";"}], "  ", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"value", " ", "as", " ", "in", " ", "the", " ", "no"}], "-", 
    RowBox[{"lag", " ", "fitted", " ", "model"}]}], " ", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"lagrate", "=", "\"\<0.5\>\""}], " ", ";"}], " ", 
  RowBox[{"(*", " ", 
   RowBox[{
   "this", " ", "must", " ", "be", " ", "experimentally", " ", "chosen", " ", 
    "to", " ", "give", " ", "the", " ", "best", " ", "fit"}], " ", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"intgrfraction", "=", "0.8"}], ";"}], " ", 
  RowBox[{"(*", " ", 
   RowBox[{
   "this", " ", "must", " ", "be", " ", "experimentally", " ", "chosen", " ", 
    "to", " ", "give", " ", "the", " ", "best", " ", "fit"}], " ", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{"mu", "=", 
  RowBox[{
   RowBox[{"Interpreter", "[", "\"\<Number\>\"", "]"}], "[", "mutrate", 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"strains", "=", "2"}], ";", 
  RowBox[{"alleles", "=", "1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"BlockRandom", "[", 
  RowBox[{
   RowBox[{"Do", "[", "\[IndentingNewLine]", 
    RowBox[{"(*", " ", 
     RowBox[{
     "parent", " ", "strains", " ", "before", " ", "and", " ", "after", " ", 
      "the", " ", "antibiotic"}], " ", "*)"}], "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{"wt", "=", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"births", "[", 
            RowBox[{"[", 
             RowBox[{"nn", ",", "1"}], "]"}], "]"}], ",", 
           RowBox[{"births", "[", 
            RowBox[{"[", 
             RowBox[{"nn", ",", "1"}], "]"}], "]"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"0", ",", "0"}], "}"}]}], "}"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{
       "intermediate", " ", "strains", " ", "before", " ", "and", " ", 
        "after", " ", "the", " ", "antibiotics"}], "*)"}], 
      "\[IndentingNewLine]", 
      RowBox[{"it", "=", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"births", "[", 
           RowBox[{"[", 
            RowBox[{"nn", ",", "1"}], "]"}], "]"}], 
          RowBox[{"{", 
           RowBox[{"1", ",", "1"}], "}"}]}], ",", 
         RowBox[{
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"birthsres", "[", 
              RowBox[{"[", 
               RowBox[{"nn", ",", "1"}], "]"}], "]"}], ">", "0"}], ",", 
            RowBox[{"birthsres", "[", 
             RowBox[{"[", 
              RowBox[{"nn", ",", "1"}], "]"}], "]"}], ",", 
            RowBox[{"RandomChoice", "[", 
             RowBox[{"Select", "[", 
              RowBox[{
               RowBox[{"birthsres", "[", 
                RowBox[{"[", 
                 RowBox[{"All", ",", "1"}], "]"}], "]"}], ",", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"#", ">", "0"}], ")"}], "&"}]}], "]"}], "]"}]}], 
           "]"}], 
          RowBox[{"{", 
           RowBox[{"intgrfraction", ",", "intgrfraction"}], "}"}]}]}], 
        "}"}]}], ";", " ", 
      RowBox[{"(*", " ", 
       RowBox[{
       "mutant", " ", "strains", " ", "before", " ", "and", " ", "after", " ",
         "the", " ", "antibiotic"}], " ", "*)"}], "\[IndentingNewLine]", 
      RowBox[{"mt", "=", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"births", "[", 
           RowBox[{"[", 
            RowBox[{"nn", ",", "1"}], "]"}], "]"}], 
          RowBox[{"{", 
           RowBox[{"1", ",", "1"}], "}"}]}], ",", 
         RowBox[{
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"birthsres", "[", 
              RowBox[{"[", 
               RowBox[{"nn", ",", "1"}], "]"}], "]"}], ">", "0"}], ",", 
            RowBox[{"birthsres", "[", 
             RowBox[{"[", 
              RowBox[{"nn", ",", "1"}], "]"}], "]"}], ",", 
            RowBox[{"RandomChoice", "[", 
             RowBox[{"Select", "[", 
              RowBox[{
               RowBox[{"birthsres", "[", 
                RowBox[{"[", 
                 RowBox[{"All", ",", "1"}], "]"}], "]"}], ",", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"#", ">", "0"}], ")"}], "&"}]}], "]"}], "]"}]}], 
           "]"}], 
          RowBox[{"{", 
           RowBox[{"1", ",", "1"}], "}"}]}]}], "}"}]}], ";", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"Export", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"NotebookDirectory", "[", "]"}], 
         "<>", "\"\<\\\\models\\\\STR_filament_lag\\\\input_params_\>\"", "<>", 
         RowBox[{"ToString", "[", "nn", "]"}], "<>", "\"\<.dat\>\""}], ",", 
        RowBox[{"Join", "[", 
         RowBox[{
          RowBox[{"{", 
           
           RowBox[{"\"\<CIP\>\"", ",", "\"\<0.66\>\"", ",", "strains", ",", 
            "alleles"}], "}"}], ",", 
          RowBox[{"wt", "[", 
           RowBox[{"[", "1", "]"}], "]"}], ",", 
          RowBox[{"it", "[", 
           RowBox[{"[", "1", "]"}], "]"}], ",", 
          RowBox[{"mt", "[", 
           RowBox[{"[", "1", "]"}], "]"}], ",", 
          RowBox[{"wt", "[", 
           RowBox[{"[", "2", "]"}], "]"}], ",", 
          RowBox[{"it", "[", 
           RowBox[{"[", "2", "]"}], "]"}], ",", 
          RowBox[{"mt", "[", 
           RowBox[{"[", "2", "]"}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"1", ",", "1"}], "}"}], ",", 
          RowBox[{"{", "\"\<end\>\"", "}"}]}], "]"}], ",", "\"\<Table\>\""}], 
       "]"}]}], "  ", 
     RowBox[{"(*", " ", 
      RowBox[{
      "we", " ", "use", " ", "the", " ", "same", " ", "model", " ", "as", " ",
        "for", " ", "CIP", " ", "but", " ", "with", " ", "different", " ", 
       "parameters", " ", "of", " ", "the", " ", "delayed", " ", "response"}],
       " ", "*)"}], "\[IndentingNewLine]", ",", 
