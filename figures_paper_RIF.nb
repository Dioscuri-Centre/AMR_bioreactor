Cell[BoxData[{
 RowBox[{"mu", "=", 
  RowBox[{
   RowBox[{"Interpreter", "[", "\"\<Number\>\"", "]"}], "[", "mutrate", 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"strains", "=", "2"}], "\[IndentingNewLine]", 
 RowBox[{"alleles", "=", 
  RowBox[{"Length", "[", "LBrates", "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"Do", "[", "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
   "parent", " ", "strains", " ", "before", " ", "and", " ", "after", " ", 
    "the", " ", "antibiotic"}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"wt", "=", 
