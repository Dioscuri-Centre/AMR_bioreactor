      RowBox[{"tmp", "=", 
       RowBox[{"Flatten", "[", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{"NumberQ", "[", 
               RowBox[{"#", "[", 
                RowBox[{"[", "1", "]"}], "]"}], "]"}], ",", 
              RowBox[{
               RowBox[{"#", "[", 
                RowBox[{"[", "1", "]"}], "]"}], "-", 
               RowBox[{"ainjs", "[", 
                RowBox[{"[", "i", "]"}], "]"}]}], ",", "#"}], "]"}], "&"}], "/@", 
           RowBox[{"Select", "[", 
            RowBox[{
             RowBox[{"simdist", "[", 
